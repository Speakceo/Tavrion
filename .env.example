# Browser (safe to expose — anon key is public by design; RLS enforces access)
# Always use the same-origin proxy path so DevTools Network never shows *.supabase.co
VITE_SUPABASE_URL=/api/sb
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server / Vite proxy target only (never prefix with VITE_ — not shipped to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (Supabase Edge Functions / Netlify — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-key
OPENROUTER_API_KEY=your-openrouter-key
RESEND_API_KEY=your-resend-key
